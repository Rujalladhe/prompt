# ---- Smart Bharat backend config ----
# Copy to .env and fill in. The app RUNS WITHOUT any of these (mock LLM + in-memory
# DB + browser voice), so you can boot it before you have keys, then paste them in
# and restart. Every integration is key-gated and degrades gracefully.

# ============================================================================
# Google Cloud suite (recommended) — ONE key powers Gemini + Cloud TTS / STT /
# Vision / Translation via their REST APIs (all accept ?key=API_KEY, no service
# account needed). Get a key: https://aistudio.google.com/apikey  and enable the
# Cloud Text-to-Speech / Speech-to-Text / Vision / Translation APIs in your GCP
# project for those features. When set, Gemini becomes the default LLM.
# ============================================================================
GOOGLE_API_KEY=
# Aliased to GEMINI_API_KEY if you prefer that name:
# GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004
# LLM backend preference: auto (prefer Gemini, then Groq, then mock) | gemini | groq
LLM_PROVIDER=auto

# Google Cloud Text-to-Speech voice (Indic-native). Browse voices in the TTS docs.
GOOGLE_TTS_VOICE=hi-IN-Wavenet-A
GOOGLE_TTS_LANGUAGE=hi-IN
# Ordered voice provider preference (comma list of: google, elevenlabs). Browser
# on-device TTS/STT is always the final fallback.
TTS_PROVIDER_ORDER=google,elevenlabs
STT_PROVIDER_ORDER=google,elevenlabs

# Google Maps geocoding (photo-complaint location). Defaults to GOOGLE_API_KEY.
GOOGLE_MAPS_API_KEY=

# Google reCAPTCHA server secret for /api/auth/* (empty = captcha disabled).
RECAPTCHA_SECRET=

# ============================================================================
# Groq (alternative LLM, free tier): https://console.groq.com/keys
# Used only when no Google key is set, or LLM_PROVIDER=groq.
# ============================================================================
GROQ_API_KEY=
GROQ_TEXT_MODEL=openai/gpt-oss-20b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ============================================================================
# ElevenLabs multilingual TTS/STT (retained fallback). Empty => browser voice.
# ============================================================================
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ============================================================================
# Data store — MongoDB Atlas. Leave empty to use the in-memory store.
# mongodb+srv://user:pass@cluster.xxxx.mongodb.net/smart_bharat
# ============================================================================
MONGODB_URI=
MONGODB_DB=smart_bharat

# ============================================================================
# Security
# ============================================================================
# REQUIRED in production (the app refuses to start with a default secret when
# NODE_ENV=production). In development an ephemeral random secret is used if empty.
JWT_SECRET=
# "demo": unauthenticated requests act as a single fixed demo citizen.
# "strict": user-scoped endpoints require a valid JWT.
AUTH_MODE=demo
# Comma-separated browser origin allowlist for CORS. Empty => reflect any origin in
# dev, deny cross-origin in production.
CORS_ORIGINS=
# Enable the /api/dev/* demo helpers (always off when NODE_ENV=production).
ENABLE_DEV_ROUTES=true
NODE_ENV=development

# ============================================================================
# Server / browser automation / demo knobs
# ============================================================================
PORT=8787
# Browser automation: "live" = real Chromium via Playwright (needs `npx playwright
# install chromium`); "sim" = safe simulation (default). HEADLESS=false shows the
# window so the user can type login/OTP directly into it.
BROWSER_AUTOMATION=sim
BROWSER_HEADLESS=false
# SLA deadline (hours) applied to new grievances. Short so demos escalate fast.
SLA_HOURS=48
# How often (seconds) the escalation worker scans for breaches.
SLA_SCAN_INTERVAL_SECONDS=15
